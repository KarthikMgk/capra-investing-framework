# ─── Application ────────────────────────────────────────────────────────────
# Project name displayed in the API docs
PROJECT_NAME="capra-investing-framework"

# Runtime environment: local | staging | production
# Controls cookie Secure flag and SameSite policy in auth
ENVIRONMENT=local

# ─── Security ────────────────────────────────────────────────────────────────
# Long random string used to sign JWT tokens (min 32 chars)
SECRET_KEY=changeme-min-32-chars-long-secret

# 32-byte base64-encoded key for general application encryption
ENCRYPTION_KEY=changeme-32-byte-base64-encoded-key==

# 32-byte base64-encoded key used to encrypt stored Kite API credentials
KITE_ENCRYPTION_KEY=changeme-32-byte-base64-encoded-key==

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Full DSN — used by some tooling; individual vars below take precedence in app
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/capra

# Host for the PostgreSQL server (Docker service name when running in compose)
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=capra
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── First superuser ─────────────────────────────────────────────────────────
# Created automatically on first startup if not present
FIRST_SUPERUSER_EMAIL=admin@capra.example.com
FIRST_SUPERUSER_PASSWORD=changeme

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"

# ─── Email (optional — leave blank to disable) ───────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ─── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=

# ─── Docker image tags ───────────────────────────────────────────────────────
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
